# Supabase — copiá estos valores desde tu proyecto en supabase.com
EXPO_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-publica

# Organización por defecto (UUID de la org "Ledor Vador" en tu Supabase)
EXPO_PUBLIC_ORG_ID=uuid-de-tu-organizacion

# Open-Meteo no requiere API key — se configura desde Supabase (configuracion_clima)
# OpenWeatherMap (alternativa, opcional)
# EXPO_PUBLIC_OPENWEATHER_API_KEY=tu-api-key
